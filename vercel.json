{
  "rewrites": [
    {
      "source": "/api/quizzes/(.*)",
      "destination": "/api/quizzes?id=$1"
    },
    {
      "source": "/api/users/(.*)",
      "destination": "/api/users?id=$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
